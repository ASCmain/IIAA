# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.venv/
.venv*/
.ipynb_checkpoints/

# Data & runtime artifacts (NOT versioned)
data/raw/
data/processed/
data/eval/runs/
qdrant_data/
debug_dump/
logs/
*.log

# OS
.DS_Store
runs/

# Corpus (non versionare originali/artefatti)
corpus/original/
corpus/processed/

# EU OJ downloads (regenerable; keep manifests + schemas versioned)
corpus/legal/eu_oj/original/**
corpus/legal/eu_oj/oracle_html/**
!corpus/legal/eu_oj/original/.gitkeep
!corpus/legal/eu_oj/oracle_html/.gitkeep
!corpus/legal/eu_oj/manifests/**
!corpus/legal/eu_oj/_schemas/**


# Telemetry (track docs/schemas, ignore generated outputs)
telemetry/**/run_*.json
telemetry/**/events_*.jsonl
telemetry/system/powermetrics_*.txt
telemetry/system/*.log

# Backup artifacts
*.bak
*.bak_*
*.BAD_*.py

# python cache
__pycache__/
*.pyc
