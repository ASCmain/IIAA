{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IIAA Document Manifest v0.1",
  "type": "object",
  "required": [
    "document_id",
    "doc_family_id",
    "source_system",
    "doc_type",
    "jurisdiction",
    "normative_level",
    "language",
    "is_consolidated",
    "precedence_rank",
    "version_priority_date",
    "scenario_tag",
    "source_url_html",
    "source_url_pdf",
    "file_name_html",
    "file_name_pdf",
    "file_path_html",
    "file_path_pdf",
    "file_sha256_html",
    "file_sha256_pdf",
    "ingested_at_utc"
  ],
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "doc_family_id": {
      "type": "string",
      "minLength": 1
    },
    "source_system": {
      "type": "string",
      "enum": [
        "eur-lex",
        "efrag",
        "iasb",
        "big4",
        "other"
      ]
    },
    "doc_type": {
      "type": "string",
      "enum": [
        "celex_consolidated",
        "celex_base",
        "oj",
        "efrag_endorsement_report",
        "other"
      ]
    },
    "jurisdiction": {
      "type": "string",
      "enum": [
        "EU",
        "other"
      ]
    },
    "normative_level": {
      "type": "string",
      "enum": [
        "EU_regulation",
        "EU_oj",
        "endorsement_status",
        "other"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "IT",
        "EN",
        "--"
      ]
    },
    "is_consolidated": {
      "type": "boolean"
    },
    "precedence_rank": {
      "type": "integer",
      "minimum": 0
    },
    "version_priority_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "scenario_tag": {
      "type": "string",
      "enum": [
        "current_law",
        "pre_endorsement",
        "historical_cutoff"
      ]
    },
    "celex_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "oj_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "oj_issue": {
      "type": [
        "string",
        "null"
      ]
    },
    "oj_publication_date": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "oj_page_start": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "act_date": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "consolidation_date": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "edition_label": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "in_force",
        "not_yet_effective",
        "superseded",
        "repealed",
        "unknown",
        null
      ]
    },
    "source_url_html": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_url_pdf": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_name_html": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_name_pdf": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_path_html": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_path_pdf": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_sha256_html": {
      "type": [
        "string",
        "null"
      ]
    },
    "file_sha256_pdf": {
      "type": [
        "string",
        "null"
      ]
    },
    "ingested_at_utc": {
      "type": "string"
    },
    "ingest_tool_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}