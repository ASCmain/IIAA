# IIAA — Environment Example (no secrets)
# Copiare in .env e valorizzare dove necessario.

# --- Ollama (locale) ---
OLLAMA_BASE_URL=http://localhost:11434

# Model roles (M1 policy: embed=mxbai-embed-large, chat=llama3.1:8b)
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_CHAT_MODEL=llama3.1:8b

# Optional roles (leave empty for M1 unless enabled)
OLLAMA_ROUTER_MODEL=functiongemma
OLLAMA_CRITIC_MODEL=
OLLAMA_WRITER_MODEL=

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=iiaa_chunks
QDRANT_API_KEY=

# --- Pipeline ---
IIAA_TIMEZONE=Europe/Rome
