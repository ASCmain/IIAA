# IIAA runtime environment template
# Do not commit your real .env
# Copy this file to .env and adjust only if needed.

QDRANT_URL=http://localhost:6333
OLLAMA_BASE_URL=http://localhost:11434

# Canonical collections used by the current project work UI
QDRANT_COLLECTION_IT=iiaa_eurlex_02023R1803_it
QDRANT_COLLECTION_EN=iiaa_eurlex_02023R1803_en

# Optional legacy compatibility
# QDRANT_COLLECTION=iiaa_eurlex_02023R1803_it

# LLM evidence classifier
EVIDENCE_CLASSIFIER_MODE=shadow
EVIDENCE_CLASSIFIER_MODEL=mistral:latest

# Project telemetry
TELEMETRY_ENABLED=true
TELEMETRY_DIR=telemetry

# Benchmark cases source
BENCHMARK_CASES_FILE=config/benchmark_cases_core.json

# Focus detection
FOCUS_DETECTION_MODE=shadow
FOCUS_DETECTION_MODEL=mistral:latest
FOCUS_CATALOG_PATH=config/focus_catalog_ifrs.json

# Semantic router
SEMANTIC_ROUTER_ENABLED=true
SEMANTIC_ROUTER_CATALOG_PATH=config/semantic_intent_catalog.json
